# Personal local install — copy to .env

# Stable 64 hex chars (so encrypted API keys survive restarts):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TITAN_ENCRYPTION_KEY=

# SQLite file (created automatically under data/)
TITAN_DB_PATH=data/titan.db

# Leave empty for dashboard-only engine. Set to http://localhost:9090 if you run a separate engine service.
TITAN_ENGINE_URL=

PORT=5000
# Bind to localhost only (default). Use 0.0.0.0 only if you need LAN access.
HOST=127.0.0.1
NODE_ENV=development

# Engine: seconds between Alpaca/Ollama trading cycles (default 90)
# TITAN_CYCLE_SECONDS=90

# Startup: full demo portfolio + fake stats (default off — use minimal strategies only)
# TITAN_SEED_DEMO=true

# Production: allow POST /api/seed (dangerous — wipes/reseeds demo data)
# TITAN_ALLOW_SEED=true

# Optional: require this value in X-Titan-Token on every /api request (expose beyond localhost)
# TITAN_API_TOKEN=

# Optional: npm run backtest — Alpaca paper API (else uses keys from app Settings DB)
# TITAN_PAPER_KEY=
# TITAN_PAPER_SECRET=

# After DTE-driven option exit, immediately attempt same-strategy re-entry (default off)
# TITAN_OPTIONS_ROLL=true
