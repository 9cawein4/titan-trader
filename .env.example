# Titan Trader GUI - Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Encryption key for API keys at rest (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TITAN_ENCRYPTION_KEY=

# SQLite database path (shared with Python engine)
# Windows: A:\TitanTrader\data\titan.db
# Linux VM: /mnt/titan-data/titan.db
TITAN_DB_PATH=A:\TitanTrader\data\titan.db

# Python trading engine URL (health/metrics/status endpoints)
TITAN_ENGINE_URL=http://titan-engine:9090

# Express server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=development
